# CodingAgent 配置

# LLM
CODING_LLM_BASE_URL=http://10.128.202.100:3010/v1
CODING_LLM_API_KEY=your-api-key
CODING_LLM_MODEL=qwen3.5-397b-a17b

# Docker
CODING_DOCKER_IMAGE=python:3.11-slim
CODING_DOCKER_NETWORK=none
CODING_DOCKER_MEMORY_LIMIT=2g
CODING_DOCKER_TIMEOUT=300

# Agent
CODING_MAX_ITERATIONS=30
CODING_APPROVE_MODE=true

# Server
CODING_HOST=0.0.0.0
CODING_PORT=8001

# PaperLab 上游
CODING_PAPERLAB_API_URL=http://127.0.0.1:8000
