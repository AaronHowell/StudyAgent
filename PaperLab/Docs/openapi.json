          },
          "summary": {
            "type": "string",
            "title": "Summary"
          },
          "asset_type": {
            "type": "string",
            "title": "Asset Type",
            "default": "unknown"
          },
          "keywords": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Keywords"
          }
        },
        "type": "object",
        "required": [
          "id",
          "document_id",
          "page_number",
          "file_name",
          "file_path",
          "file_url",
          "figure_label",
