    "/documents/ingestion-status": {
      "post": {
        "summary": "Get Document Ingestion Status",
        "description": "Check whether one local document has already been ingested.\n\n作用:\n    根据文档路径构造稳定的文档 id，并查询该文档是否已存在于数据库中。\n\nArgs:\n    payload: 包含本地文档路径的请求体。\n\nReturns:\n    DocumentIngestionStatusResponse: 当前文档的入库状态响应。",
        "operationId": "get_document_ingestion_status_documents_ingestion_status_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentIngestionStatusRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentIngestionStatusResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/documents/ingest": {
      "get": {
        "summary": "List Ingestion Tasks",
        "description": "Return recent ingestion tasks for the desktop UI.",
        "operationId": "list_ingestion_tasks_documents_ingest_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/IngestionTaskSummary"
                  },
                  "type": "array",
                  "title": "Response List Ingestion Tasks Documents Ingest Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Ingest Document",
        "description": "Queue one local document for background ingestion.\n\n作用:\n    将入库流程放到后台线程池中执行，避免前端请求被长时间阻塞。\n\nArgs:\n    payload: 文档路径和目标项目的请求体。\n\nReturns:\n    IngestDocumentResponse: 新建或复用的任务信息。",
        "operationId": "ingest_document_documents_ingest_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IngestDocumentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestDocumentResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
