  "components": {
    "schemas": {
      "AgentAnswerStreamRequest": {
        "properties": {
          "question": {
            "type": "string",
            "title": "Question",
            "description": "User question for grounded QA"
          },
          "project_id": {
            "type": "string",
            "title": "Project Id",
            "description": "Target project identifier"
          },
          "document_limit": {
            "type": "integer",
            "maximum": 20.0,
            "minimum": 1.0,
            "title": "Document Limit",
            "default": 5
          },
          "chunk_limit": {
            "type": "integer",
            "maximum": 50.0,
            "minimum": 1.0,
            "title": "Chunk Limit",
            "default": 8
          },
          "asset_limit": {
            "type": "integer",
            "maximum": 50.0,
            "minimum": 1.0,
            "title": "Asset Limit",
            "default": 6
          }
        },
        "type": "object",
        "required": [
          "question",
          "project_id"
        ],
        "title": "AgentAnswerStreamRequest",
        "description": "Request payload for one streaming grounded-answer run."
      },
      "BatchIngestDocumentsRequest": {
        "properties": {
          "project_id": {
            "type": "string",
            "title": "Project Id",
            "description": "Target project identifier"
          },
          "paths": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Paths",
            "description": "Absolute paths to local documents"
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "paths"
        ],
        "title": "BatchIngestDocumentsRequest",
        "description": "Request payload for scheduling multiple local documents at once."
      },
      "BatchIngestDocumentsResponse": {
        "properties": {
          "tasks": {
            "items": {
              "$ref": "#/components/schemas/IngestionTaskSummary"
            },
            "type": "array",
            "title": "Tasks"
          }
        },
        "type": "object",
        "required": [
          "tasks"
        ],
        "title": "BatchIngestDocumentsResponse",
        "description": "Response payload for one batch ingestion request."
      },
      "ChatCommandInput": {
        "properties": {
          "update": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ChatStateUpdate"
              },
              {
                "type": "null"
              }
            ]
          },
          "resume": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "$ref": "#/components/schemas/ChatResumeCommand"
              },
              {
                "type": "null"
              }
            ],
            "title": "Resume"
          }
        },
        "type": "object",
        "title": "ChatCommandInput",
        "description": "Frontend command payload used for guidance injection and resume."
      },
      "ChatInterruptPayload": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "value": {
            "additionalProperties": true,
            "type": "object",
            "title": "Value"
          }
        },
        "type": "object",
        "required": [
          "id",
          "value"
        ],
        "title": "ChatInterruptPayload",
        "description": "Serializable interrupt record returned to the frontend."
      },
      "ChatMessageInput": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type",
            "description": "LangChain-compatible message type",
            "default": "human"
          },
          "content": {
            "type": "string",
            "title": "Content",
            "description": "User-visible message content"
          }
        },
        "type": "object",
        "required": [
          "content"
        ],
        "title": "ChatMessageInput",
        "description": "Frontend message item accepted by the chat bridge."
      },
      "ChatMessagePayload": {
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Id"
          },
          "type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Type"
          },
          "role": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Role"
          },
          "content": {
            "title": "Content"
          },
          "additional_kwargs": {
            "additionalProperties": true,
            "type": "object",
            "title": "Additional Kwargs"
          },
          "response_metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Response Metadata"
          }
        },
        "type": "object",
        "required": [
          "content"
        ],
        "title": "ChatMessagePayload",
        "description": "Serialized LangChain message returned to the desktop UI."
      },
      "ChatResumeCommand": {
        "properties": {
          "action": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Action"
          }
        },
        "type": "object",
        "title": "ChatResumeCommand",
        "description": "Opaque resume payload passed back into one interrupted graph."
      },
      "ChatRunRequest": {
        "properties": {
          "project_id": {
            "type": "string",
            "title": "Project Id",
            "description": "Target project identifier"
          },
          "thread_id": {
            "type": "string",
            "title": "Thread Id",
            "description": "Persistent graph thread identifier"
          },
          "input": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Input",
            "description": "Initial graph input, typically {messages: [...]}"
          },
          "command": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ChatCommandInput"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "thread_id"
        ],
        "title": "ChatRunRequest",
        "description": "Request payload for one direct LangGraph-backed chat run."
      },
      "ChatStateResponse": {
        "properties": {
          "thread_id": {
            "type": "string",
            "title": "Thread Id"
          },
          "project_id": {
            "type": "string",
            "title": "Project Id"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/ChatMessagePayload"
            },
            "type": "array",
            "title": "Messages"
          },
          "interrupt": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ChatInterruptPayload"
              },
              {
                "type": "null"
              }
            ]
          },
          "next_nodes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Next Nodes"
          }
        },
        "type": "object",
        "required": [
          "thread_id",
          "project_id"
        ],
        "title": "ChatStateResponse",
        "description": "Thread snapshot returned by the FastAPI chat bridge."
      },
      "ChatStateUpdate": {
        "properties": {
          "messages": {
            "items": {
              "$ref": "#/components/schemas/ChatMessageInput"
            },
            "type": "array",
            "title": "Messages"
          }
        },
        "type": "object",
        "title": "ChatStateUpdate",
        "description": "State fragment applied before a resume command."
      },
